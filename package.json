{
  "name": "apiscribe",
  "version": "0.2.0",
  "description": "Scan any backend project and generate API documentation with AI",
  "type": "module",
  "bin": {
    "apiscribe": "./bin/apiscribe.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "prepublishOnly": "npm run build && npm run test && npm run lint"
  },
  "keywords": [
    "cli",
    "api",
    "documentation",
    "openapi",
    "llm",
    "ai",
    "express",
    "nextjs",
    "supabase",
    "fastify",
    "developer-tools"
  ],
  "author": "joseguapo",
  "repository": {
    "type": "git",
    "url": "https://github.com/Overtaked00/apiscribe.git"
  },
  "homepage": "https://github.com/Overtaked00/apiscribe#readme",
  "bugs": {
    "url": "https://github.com/Overtaked00/apiscribe/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "openai": "^4.82.0",
    "ora": "^8.2.0",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@types/tar": "^6.1.13",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
